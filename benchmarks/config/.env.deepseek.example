# VulnHunterX — DeepSeek credentials (model-matrix template)
# Copy to a repo-root `.env.deepseek` and fill in real values.
#
# Uses LiteLLM's native `deepseek/` provider so per-call cost is priced from the
# model name (no static price table). Known ids (deepseek-chat / deepseek-reasoner
# / deepseek-v3.2) are priced immediately; newer ids (deepseek-v4-flash/-pro) may
# report $0 until LiteLLM's price table includes them.
LLM_PROVIDER=deepseek

# DeepSeek model (1M context, dual-mode):
#   deepseek-v4-flash — cheap tier
#   deepseek-v4-pro   — frontier tier
#   deepseek-chat / deepseek-reasoner / deepseek-v3.2 — LiteLLM-priced today
LLM_MODEL=deepseek-v4-flash
# LLM_MODEL=deepseek-v4-pro

# DeepSeek API key (https://platform.deepseek.com/api_keys).
DEEPSEEK_API_KEY=sk-REPLACE_ME

# Optional — LiteLLM defaults to https://api.deepseek.com.
# DEEPSEEK_API_BASE=https://api.deepseek.com
